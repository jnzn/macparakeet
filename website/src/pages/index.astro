---
import Layout from '../layouts/Layout.astro';
---

<Layout title="MacParakeet - The Fastest Local Transcription for Mac">
  <!-- Header -->
  <header class="fixed top-0 left-0 right-0 z-50 bg-slate-950/80 backdrop-blur-md border-b border-slate-800">
    <nav class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
      <a href="/" class="text-xl font-bold flex items-center gap-2">
        <span class="text-2xl">🦜</span>
        MacParakeet
      </a>
      <div class="flex items-center gap-6">
        <a href="#features" class="text-slate-400 hover:text-white transition">Features</a>
        <a href="#pricing" class="text-slate-400 hover:text-white transition">Pricing</a>
        <a href="#faq" class="text-slate-400 hover:text-white transition">FAQ</a>
        <a href="#download" class="bg-blue-600 hover:bg-blue-500 px-4 py-2 rounded-lg font-medium transition">
          Download
        </a>
      </div>
    </nav>
  </header>

  <main>
    <!-- Hero -->
    <section class="pt-32 pb-20 px-6">
      <div class="max-w-4xl mx-auto text-center">
        <div class="inline-block bg-blue-600/20 text-blue-400 px-4 py-1 rounded-full text-sm font-medium mb-6">
          100% Local • No Cloud • No Subscriptions
        </div>
        <h1 class="text-5xl md:text-6xl font-bold mb-6 leading-tight">
          The Fastest Local Transcription for Mac
        </h1>
        <p class="text-xl text-slate-400 mb-8 max-w-2xl mx-auto">
          Transcribe audio at <span class="text-white font-semibold">300x realtime speed</span>, entirely on your Mac.
          Your audio never leaves your device.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="#download" class="bg-blue-600 hover:bg-blue-500 px-8 py-3 rounded-lg font-semibold text-lg transition">
            Download Free Trial
          </a>
          <a href="#features" class="border border-slate-700 hover:border-slate-500 px-8 py-3 rounded-lg font-medium transition">
            See Features
          </a>
        </div>
        <p class="text-slate-500 mt-4 text-sm">
          macOS 14.2+ • Apple Silicon (M1/M2/M3/M4)
        </p>
      </div>
    </section>

    <!-- Speed Benchmark -->
    <section class="py-16 px-6 bg-slate-900/50">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-3xl font-bold mb-4">Transcribe a 3-hour podcast in 90 seconds</h2>
        <p class="text-slate-400 mb-8">
          Powered by NVIDIA's Parakeet TDT model, optimized for Apple Silicon.
        </p>
        <div class="grid md:grid-cols-3 gap-8">
          <div class="bg-slate-800/50 rounded-xl p-6">
            <div class="text-4xl font-bold text-blue-400 mb-2">300x</div>
            <div class="text-slate-400">Realtime Speed</div>
          </div>
          <div class="bg-slate-800/50 rounded-xl p-6">
            <div class="text-4xl font-bold text-blue-400 mb-2">6.3%</div>
            <div class="text-slate-400">Word Error Rate</div>
          </div>
          <div class="bg-slate-800/50 rounded-xl p-6">
            <div class="text-4xl font-bold text-blue-400 mb-2">100%</div>
            <div class="text-slate-400">Local Processing</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Features -->
    <section id="features" class="py-20 px-6">
      <div class="max-w-6xl mx-auto">
        <h2 class="text-4xl font-bold text-center mb-4">Everything you need. Nothing you don't.</h2>
        <p class="text-slate-400 text-center mb-12 max-w-2xl mx-auto">
          MacParakeet does one thing exceptionally well: transcribe audio fast and privately.
        </p>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          <!-- Feature 1 -->
          <div class="bg-slate-900 rounded-xl p-6 border border-slate-800">
            <div class="text-3xl mb-4">⚡</div>
            <h3 class="text-xl font-semibold mb-2">Blazing Fast</h3>
            <p class="text-slate-400">
              Transcribe 1 hour of audio in 12 seconds on Apple Silicon. No waiting, no cloud delays.
            </p>
          </div>
          <!-- Feature 2 -->
          <div class="bg-slate-900 rounded-xl p-6 border border-slate-800">
            <div class="text-3xl mb-4">🔒</div>
            <h3 class="text-xl font-semibold mb-2">100% Private</h3>
            <p class="text-slate-400">
              Audio is processed entirely on your Mac. Nothing is uploaded. Ever.
            </p>
          </div>
          <!-- Feature 3 -->
          <div class="bg-slate-900 rounded-xl p-6 border border-slate-800">
            <div class="text-3xl mb-4">🎯</div>
            <h3 class="text-xl font-semibold mb-2">Dead Simple</h3>
            <p class="text-slate-400">
              Drag a file. Get text. That's it. No accounts, no setup, no complexity.
            </p>
          </div>
          <!-- Feature 4 -->
          <div class="bg-slate-900 rounded-xl p-6 border border-slate-800">
            <div class="text-3xl mb-4">🎤</div>
            <h3 class="text-xl font-semibold mb-2">System Dictation</h3>
            <p class="text-slate-400">
              Press a hotkey to dictate anywhere on your Mac. Replaces Apple's built-in dictation.
            </p>
          </div>
          <!-- Feature 5 -->
          <div class="bg-slate-900 rounded-xl p-6 border border-slate-800">
            <div class="text-3xl mb-4">📄</div>
            <h3 class="text-xl font-semibold mb-2">Export Anywhere</h3>
            <p class="text-slate-400">
              Export to TXT, SRT, VTT, Word, or PDF. Perfect for videos, podcasts, and documents.
            </p>
          </div>
          <!-- Feature 6 -->
          <div class="bg-slate-900 rounded-xl p-6 border border-slate-800">
            <div class="text-3xl mb-4">🌍</div>
            <h3 class="text-xl font-semibold mb-2">100+ Languages</h3>
            <p class="text-slate-400">
              Automatic language detection. Transcribe content in any major language.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Pricing -->
    <section id="pricing" class="py-20 px-6 bg-slate-900/50">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-4xl font-bold mb-4">Simple, fair pricing</h2>
        <p class="text-slate-400 mb-12">
          Pay once. Use forever. No subscriptions. No accounts.
        </p>
        <div class="grid md:grid-cols-2 gap-8 max-w-3xl mx-auto">
          <!-- Free -->
          <div class="bg-slate-900 rounded-xl p-8 border border-slate-800">
            <h3 class="text-2xl font-bold mb-2">Free Trial</h3>
            <div class="text-4xl font-bold mb-4">$0</div>
            <ul class="text-left text-slate-400 space-y-3 mb-8">
              <li class="flex items-center gap-2">
                <span class="text-green-400">✓</span> 15 minutes per day
              </li>
              <li class="flex items-center gap-2">
                <span class="text-green-400">✓</span> All file formats
              </li>
              <li class="flex items-center gap-2">
                <span class="text-green-400">✓</span> System dictation
              </li>
              <li class="flex items-center gap-2">
                <span class="text-slate-600">✗</span> Limited export options
              </li>
            </ul>
            <a href="#download" class="block w-full border border-slate-600 hover:border-slate-400 py-3 rounded-lg font-medium transition">
              Download Free
            </a>
          </div>
          <!-- Pro -->
          <div class="bg-gradient-to-br from-blue-600/20 to-purple-600/20 rounded-xl p-8 border border-blue-500/50">
            <div class="bg-blue-600 text-xs px-2 py-1 rounded-full inline-block mb-2">RECOMMENDED</div>
            <h3 class="text-2xl font-bold mb-2">Pro</h3>
            <div class="text-4xl font-bold mb-4">$49 <span class="text-lg font-normal text-slate-400">once</span></div>
            <ul class="text-left text-slate-300 space-y-3 mb-8">
              <li class="flex items-center gap-2">
                <span class="text-green-400">✓</span> Unlimited transcription
              </li>
              <li class="flex items-center gap-2">
                <span class="text-green-400">✓</span> All file formats
              </li>
              <li class="flex items-center gap-2">
                <span class="text-green-400">✓</span> System dictation
              </li>
              <li class="flex items-center gap-2">
                <span class="text-green-400">✓</span> All export formats
              </li>
              <li class="flex items-center gap-2">
                <span class="text-green-400">✓</span> AI text refinement
              </li>
              <li class="flex items-center gap-2">
                <span class="text-green-400">✓</span> Lifetime updates
              </li>
            </ul>
            <a href="#download" class="block w-full bg-blue-600 hover:bg-blue-500 py-3 rounded-lg font-semibold transition">
              Buy Pro - $49
            </a>
          </div>
        </div>
        <p class="text-slate-500 mt-8 text-sm">
          30-day money-back guarantee. No questions asked.
        </p>
      </div>
    </section>

    <!-- Comparison -->
    <section class="py-20 px-6">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-4xl font-bold text-center mb-12">How we compare</h2>
        <div class="overflow-x-auto">
          <table class="w-full text-left">
            <thead>
              <tr class="border-b border-slate-800">
                <th class="py-4 px-4"></th>
                <th class="py-4 px-4 text-blue-400">MacParakeet</th>
                <th class="py-4 px-4 text-slate-400">MacWhisper</th>
                <th class="py-4 px-4 text-slate-400">Superwhisper</th>
                <th class="py-4 px-4 text-slate-400">Otter.ai</th>
              </tr>
            </thead>
            <tbody class="text-slate-400">
              <tr class="border-b border-slate-800/50">
                <td class="py-4 px-4">Price</td>
                <td class="py-4 px-4 text-white font-medium">$49 once</td>
                <td class="py-4 px-4">$79 once</td>
                <td class="py-4 px-4">$250 once</td>
                <td class="py-4 px-4">$16/mo</td>
              </tr>
              <tr class="border-b border-slate-800/50">
                <td class="py-4 px-4">Local Processing</td>
                <td class="py-4 px-4 text-green-400">✓</td>
                <td class="py-4 px-4 text-green-400">✓</td>
                <td class="py-4 px-4 text-green-400">✓</td>
                <td class="py-4 px-4 text-red-400">✗ Cloud</td>
              </tr>
              <tr class="border-b border-slate-800/50">
                <td class="py-4 px-4">Parakeet Speed (300x)</td>
                <td class="py-4 px-4 text-green-400">✓</td>
                <td class="py-4 px-4 text-yellow-400">Added later</td>
                <td class="py-4 px-4 text-red-400">✗</td>
                <td class="py-4 px-4 text-red-400">✗</td>
              </tr>
              <tr class="border-b border-slate-800/50">
                <td class="py-4 px-4">No Account Required</td>
                <td class="py-4 px-4 text-green-400">✓</td>
                <td class="py-4 px-4 text-green-400">✓</td>
                <td class="py-4 px-4 text-green-400">✓</td>
                <td class="py-4 px-4 text-red-400">✗</td>
              </tr>
              <tr>
                <td class="py-4 px-4">Simplicity</td>
                <td class="py-4 px-4 text-green-400">Simple</td>
                <td class="py-4 px-4 text-yellow-400">Complex</td>
                <td class="py-4 px-4 text-yellow-400">Complex</td>
                <td class="py-4 px-4 text-yellow-400">Moderate</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section id="faq" class="py-20 px-6 bg-slate-900/50">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-4xl font-bold text-center mb-12">Frequently Asked Questions</h2>
        <div class="space-y-6">
          <div class="bg-slate-900 rounded-xl p-6 border border-slate-800">
            <h3 class="text-lg font-semibold mb-2">Is my audio really private?</h3>
            <p class="text-slate-400">
              Yes. MacParakeet processes everything locally using the Parakeet TDT model. Your audio never leaves your Mac - not for processing, not for analytics, not for anything.
            </p>
          </div>
          <div class="bg-slate-900 rounded-xl p-6 border border-slate-800">
            <h3 class="text-lg font-semibold mb-2">Do I need an internet connection?</h3>
            <p class="text-slate-400">
              No. MacParakeet works completely offline. Once installed, you never need internet access.
            </p>
          </div>
          <div class="bg-slate-900 rounded-xl p-6 border border-slate-800">
            <h3 class="text-lg font-semibold mb-2">What's the difference from MacWhisper?</h3>
            <p class="text-slate-400">
              MacParakeet is built around the Parakeet model from day one (10x faster than Whisper), has a simpler interface, and costs $30 less. MacWhisper added Parakeet support later as an option.
            </p>
          </div>
          <div class="bg-slate-900 rounded-xl p-6 border border-slate-800">
            <h3 class="text-lg font-semibold mb-2">What Mac do I need?</h3>
            <p class="text-slate-400">
              MacParakeet requires macOS 14.2+ and Apple Silicon (M1, M2, M3, or M4). Intel Macs are not supported because Parakeet requires Metal acceleration.
            </p>
          </div>
          <div class="bg-slate-900 rounded-xl p-6 border border-slate-800">
            <h3 class="text-lg font-semibold mb-2">Is there a subscription?</h3>
            <p class="text-slate-400">
              No. $49 is a one-time purchase that includes lifetime updates. No monthly fees, no annual renewals, no upsells.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section id="download" class="py-20 px-6">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-4xl font-bold mb-4">Ready to transcribe at 300x speed?</h2>
        <p class="text-slate-400 mb-8 text-lg">
          Download the free trial. No account required.
        </p>
        <a href="#" class="inline-block bg-blue-600 hover:bg-blue-500 px-8 py-4 rounded-lg font-semibold text-lg transition">
          Download MacParakeet
        </a>
        <p class="text-slate-500 mt-4 text-sm">
          v0.1.0 • 180 MB • macOS 14.2+
        </p>
      </div>
    </section>
  </main>

  <!-- Footer -->
  <footer class="py-12 px-6 border-t border-slate-800">
    <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="flex items-center gap-2">
        <span class="text-xl">🦜</span>
        <span class="font-semibold">MacParakeet</span>
      </div>
      <div class="flex gap-6 text-slate-400 text-sm">
        <a href="/privacy" class="hover:text-white transition">Privacy Policy</a>
        <a href="mailto:support@macparakeet.com" class="hover:text-white transition">Contact</a>
      </div>
      <div class="text-slate-500 text-sm">
        © 2026 MacParakeet. All rights reserved.
      </div>
    </div>
  </footer>
</Layout>
